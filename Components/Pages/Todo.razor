@page "/"
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
@using Microsoft.EntityFrameworkCore
@using TodoList

<h3>Todo (@todos.Count(todo => !todo.IsDone))</h3>

<div style="background-color: #f8d7da; color: #721c24; padding: 10px; border-radius: 4px; margin-bottom: 15px; font-size: 0.9em;">
    <strong>Status aktivne baze:</strong> <code style="background: white; padding: 2px 4px;">Uspješno povezano na poslužitelj</code>
</div>

<ul>
    @foreach (var todo in todos)
    {
        <li style="margin-bottom: 8px; list-style-type: none; display: flex; align-items: center;">
            <input type="checkbox" checked="@todo.IsDone" @onchange="(e) => ToggleDone(todo, e)" disabled style="margin-right: 10px;" />

            <span style="@(todo.IsDone ? "text-decoration: line-through; color: gray;" : "")">
                @todo.Title
            </span>

            <span style="margin-left: 10px; font-size: 0.85em; color: #666; background-color: #f0f0f0; padding: 2px 6px; border-radius: 4px;">
                @todo.Sifra
            </span>

            @if (todo.DueDate.HasValue)
            {
                <span style="margin-left: 10px; font-size: 0.85em; color: #666; background-color: #f0f0f0; padding: 2px 6px; border-radius: 4px;">
                    📅 @todo.DueDate.Value.ToString("dd.MM.yyyy.")
                </span>
            }

            @if (todo.PdfContent != null)
            {
                <button @onclick="() => ViewPdf(todo)" style="margin-left: 10px; background-color: #4CAF50; color: white; border: none; padding: 2px 8px; border-radius: 4px; cursor: pointer;">
                    👁️ Prikaži PDF
                </button>
            }
        </li>
    }
</ul>

<div style="margin-top: 40px; padding: 15px; border: 2px dashed #ff9800; background-color: #fffde7; border-radius: 8px; max-width: 400px;">
    <h4 style="margin-top: 0; color: #e65100;">Alat za sinkronizaciju baze podataka</h4>
    <p style="font-size: 0.9em; margin-bottom: 10px;">Odaberite bazu s vašeg računala kako biste je ugurali na Railway:</p>
    <Microsoft.AspNetCore.Components.Forms.InputFile OnChange="UploadDatabaseToServer" accept=".db" />
    @if (!string.IsNullOrEmpty(syncStatus))
    {
        <p style="color: green; font-weight: bold; margin-top: 5px;">@syncStatus</p>
    }
</div>

@code {
    private List<TodoItem> todos = [];
    private string syncStatus = "";

    [Inject] private IDbContextFactory<TodoDbContext> DbFactory { get; set; } = default!;
    [Inject] private Microsoft.JSInterop.IJSRuntime JS { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        await context.Database.EnsureCreatedAsync();
        todos = await context.Todos.ToListAsync();
    }

    private async Task ViewPdf(TodoItem todo)
    {
        if (todo.PdfContent != null)
        {
            await JS.InvokeVoidAsync("preparePdfWindow");
            using var stream = new MemoryStream(todo.PdfContent);
            using var streamRef = new Microsoft.JSInterop.DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("viewPdfFromStream", streamRef);
        }
    }

    private async Task ToggleDone(TodoItem todo, ChangeEventArgs e)
    {
        todo.IsDone = (bool)(e.Value ?? false);
        using var context = DbFactory.CreateDbContext();
        context.Todos.Update(todo);
        await context.SaveChangesAsync();
    }

    // IZRAVNI NEPOGREŠIVI SQLite ČITAČ PODATAKA (Bypassa lockove i migracije)
    private async Task UploadDatabaseToServer(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null) return;

            syncStatus = "⏳ Čitam podatke iz odabrane datoteke...";
            StateHasChanged();

            // 1. Čitamo bazu isključivo kao niz bajtova u RAM (razbija Windows File Lock)
            byte[] bajtoviBaze;
            using (var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024))
            {
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                bajtoviBaze = ms.ToArray();
            }

            // 2. Pišemo privremenu datoteku na disk poslužitelja
            var tempPath = Path.Combine(Path.GetTempPath(), Guid.NewGuid().ToString() + ".db");
            await File.WriteAllBytesAsync(tempPath, bajtoviBaze);

            // 3. Koristimo izravnu SQLite vezu i ručno izvlačimo podatke iz tablice Todos sa slike
            List<TodoItem> stavkeZaPrenijeti = [];
            using (var conn = new Microsoft.Data.Sqlite.SqliteConnection($"Data Source={tempPath}"))
            {
                await conn.OpenAsync();
                var cmd = new Microsoft.Data.Sqlite.SqliteCommand("SELECT Title, Sifra, IsDone, DueDate, PdfContent, PdfFileName FROM Todos", conn);
                using (var reader = await cmd.ExecuteReaderAsync())
                {
                    while (await reader.ReadAsync())
                    {
                        var stavka = new TodoItem
                        {
                            Title = reader.IsDBNull(0) ? null : reader.GetString(0),
                            Sifra = reader.IsDBNull(1) ? null : reader.GetString(1),
                            IsDone = reader.GetInt32(2) == 1,
                            DueDate = reader.IsDBNull(3) ? null : DateTime.Parse(reader.GetString(3)),
                            PdfContent = reader.IsDBNull(4) ? null : (byte[])reader.GetValue(4),
                            PdfFileName = reader.IsDBNull(5) ? null : reader.GetString(5)
                        };
                        stavkeZaPrenijeti.Add(stavka);
                    }
                }
                await conn.CloseAsync();
            }

            if (File.Exists(tempPath)) File.Delete(tempPath);

            syncStatus = $"⏳ Pročitano {stavkeZaPrenijeti.Count} stavki. Prepisujem tablicu na serveru...";
            StateHasChanged();

            // 4. Upisujemo podatke u produkcijsku bazu kroz čisti SQL
            using (var prodContext = DbFactory.CreateDbContext())
            {
                await prodContext.Database.ExecuteSqlRawAsync("DELETE FROM Todos;");

                foreach (var stavka in stavkeZaPrenijeti)
                {
                    var novaStavka = new TodoItem
                    {
                        Title = stavka.Title,
                        Sifra = stavka.Sifra,
                        IsDone = stavka.IsDone,
                        DueDate = stavka.DueDate,
                        PdfContent = stavka.PdfContent,
                        PdfFileName = stavka.PdfFileName
                    };
                    prodContext.Todos.Add(novaStavka);
                }

                await prodContext.SaveChangesAsync();
                todos = await prodContext.Todos.ToListAsync();
            }

            syncStatus = $"🚀 Sinkronizacija uspješna! Na webu se sada nalaze sve {todos.Count} stavke.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            syncStatus = $"❌ Greška tijekom prijenosa: {ex.Message}";
        }
    }

    private string GetDatabasePath()
    {
        return "todonova.db (Aktivna produkcijska baza)";
    }
}


    private string GetDatabasePath()
    {
        return "todonova.db (Aktivna Docker baza)";
    }
}
