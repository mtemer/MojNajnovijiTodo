@page "/"
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
@using Microsoft.EntityFrameworkCore
@using TodoList
@using System.Text.Json

<h3>Todo (@todos.Count(todo => !todo.IsDone))</h3>

@if (Env.IsDevelopment())
{
    <div style="background-color: #f8d7da; color: #721c24; padding: 10px; border-radius: 4px; margin-bottom: 15px; font-size: 0.9em;">
        <strong>LOKALNI RAD:</strong> <code style="background: white; padding: 2px 4px;">Uspješno povezano</code>
    </div>
}

<ul>
    @foreach (var todo in todos)
    {
        <li style="margin-bottom: 8px; list-style-type: none; display: flex; align-items: center;">
            <input type="checkbox" checked="@todo.IsDone" @onchange="(e) => ToggleDone(todo, e)" disabled="@(!Env.IsDevelopment())" style="margin-right: 10px;" />

            <span style="@(todo.IsDone ? "text-decoration: line-through; color: gray;" : "")">
                @todo.Title
            </span>

            <span style="margin-left: 10px; font-size: 0.85em; color: #666; background-color: #f0f0f0; padding: 2px 6px; border-radius: 4px;">
                @todo.Sifra
            </span>

            @if (todo.DueDate.HasValue)
            {
                <span style="margin-left: 10px; font-size: 0.85em; color: #666; background-color: #f0f0f0; padding: 2px 6px; border-radius: 4px;">
                    📅 @todo.DueDate.Value.ToString("dd.MM.yyyy.")
                </span>
            }

            @if (todo.PdfContent != null)
            {
                <button @onclick="() => ViewPdf(todo)" style="margin-left: 10px; background-color: #4CAF50; color: white; border: none; padding: 2px 8px; border-radius: 4px; cursor: pointer;">
                    👁️ Prikaži PDF
                </button>
            }

            @if (Env.IsDevelopment())
            {
                <button @onclick="() => DeleteTodo(todo)" style="margin-left: 15px; color: red; border: none; background: none; cursor: pointer;">
                    Briši
                </button>
            }
        </li>
    }
</ul>

<!-- FORMA ZA UPIS: Sada je trajno otključana i uvijek vidljiva lokalno na računalu -->
@if (Env.IsDevelopment())
{
    <div style="margin-top: 20px; display: flex; flex-direction: column; gap: 8px; max-width: 300px; padding: 15px; background-color: #f9f9f9; border: 1px solid #ddd; border-radius: 6px;">
        <h4 style="margin-top: 0;">Novi unos</h4>
        <input placeholder="Upis Šifre" @bind="newSifra" style="padding: 4px;" />
        <input placeholder="Upis #Dokumenta" @bind="newTodo" style="padding: 4px;" />
        <input type="date" @bind="newTodoDueDate" style="padding: 4px;" />
        <label style="font-size: 0.9em; font-weight: bold; margin-top: 5px;">Dodaj PDF dokument:</label>
        <Microsoft.AspNetCore.Components.Forms.InputFile OnChange="HandleFileSelected" accept=".pdf" />
        <button @onclick="AddTodo" style="background-color: #FFDE21; font-weight: bold; padding: 8px; margin-top: 5px; border: 1px solid #ccb11b; border-radius: 4px; cursor: pointer;">Add todo</button>
    </div>
}
else
{
    <p style="margin-top: 20px; color: #666; font-style: italic;">
        ⚠️ Na produkcijskom poslužitelju omogućen je isključivo pregled podataka.
    </p>
}

<!-- ALAT ZA SINKRONIZACIJU: Kopiranje i uvoz podataka (0% šanse za File Lock) -->
<div style="margin-top: 40px; padding: 15px; border: 2px dashed #ff9800; background-color: #fffde7; border-radius: 8px; max-width: 500px;">
    <h4 style="margin-top: 0; color: #e65100;">Alat za tekstualnu sinkronizaciju podataka</h4>
    
    @if (Env.IsDevelopment())
    {
        <p style="font-size: 0.9em; margin-bottom: 10px;">Kliknite gumb ispod kako biste kopirali sve lokalne stavke u međuspremnik:</p>
        <button @onclick="KopirajPodatkeKaoTekst" style="background-color: #2196F3; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-weight: bold;">
            📋 Kopiraj sve stavke s računala
        </button>
    }
    else
    {
        <p style="font-size: 0.9em; margin-bottom: 10px;">Zalijepite tekst kopiran s računala u polje ispod i kliknite Uvezi:</p>
        <textarea @bind="jsonTekst" placeholder="Ovdje desni klik -> Zalijepi (Paste)" style="width: 100%; height: 100px; margin-bottom: 10px; font-family: monospace; font-size: 0.85em;"></textarea>
        <button @onclick="UveziPodatkeIzTeksta" style="background-color: #4CAF50; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-weight: bold;">
            📥 Uvezi podatke na Web
        </button>
    }

    @if (!string.IsNullOrEmpty(syncStatus))
    {
        <p style="color: green; font-weight: bold; margin-top: 8px; margin-bottom: 0;">@syncStatus</p>
    }
</div>

@code {
    private List<TodoItem> todos = [];
    private string jsonTekst = "";
    private string syncStatus = "";

    // Varijable za unos novog zadatka
    private string? newTodo;
    private string? newSifra;
    private DateTime? newTodoDueDate;
    private byte[]? uploadedPdfContent;
    private string? uploadedPdfFileName;

    [Inject] private IDbContextFactory<TodoDbContext> DbFactory { get; set; } = default!;
    [Inject] private Microsoft.JSInterop.IJSRuntime JS { get; set; } = default!;
    [Inject] private Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        await context.Database.EnsureCreatedAsync();
        todos = await context.Todos.ToListAsync();
    }

    private async Task HandleFileSelected(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && file.ContentType == "application/pdf")
        {
            long maxFileSize = 5242880; // 5MB
            using var stream = file.OpenReadStream(maxFileSize);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            uploadedPdfContent = memoryStream.ToArray();
            uploadedPdfFileName = file.Name;
        }
    }

    private async Task AddTodo()
    {
        if (!string.IsNullOrWhiteSpace(newTodo))
        {
            var newItem = new TodoItem 
            { 
                Title = newTodo, 
                IsDone = false, 
                DueDate = newTodoDueDate, 
                Sifra = newSifra, 
                PdfContent = uploadedPdfContent, 
                PdfFileName = uploadedPdfFileName 
            };
            
            using var context = DbFactory.CreateDbContext();
            context.Todos.Add(newItem);
            await context.SaveChangesAsync();
            
            todos.Add(newItem);
            
            // Čišćenje polja nakon unosa
            newTodo = string.Empty; 
            newSifra = string.Empty; 
            newTodoDueDate = null; 
            uploadedPdfContent = null; 
            uploadedPdfFileName = null;
        }
    }

    private async Task ViewPdf(TodoItem todo)
    {
        if (todo.PdfContent != null)
        {
            await JS.InvokeVoidAsync("preparePdfWindow");
            using var stream = new MemoryStream(todo.PdfContent);
            using var streamRef = new Microsoft.JSInterop.DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("viewPdfFromStream", streamRef);
        }
    }

    private async Task ToggleDone(TodoItem todo, ChangeEventArgs e)
    {
        todo.IsDone = (bool)(e.Value ?? false);
        using var context = DbFactory.CreateDbContext();
        context.Todos.Update(todo);
        await context.SaveChangesAsync();
    }

    private async Task DeleteTodo(TodoItem todoToRemove)
    {
        using var context = DbFactory.CreateDbContext();
        context.Todos.Remove(todoToRemove);
        await context.SaveChangesAsync();
        todos.Remove(todoToRemove);
    }

    // LOKALNI KORAK: Pretvara živu bazu u tekst i sprema u Clipboard
    private async Task KopirajPodatkeKaoTekst()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            var sveStavke = await context.Todos.ToListAsync();
            var tekst = JsonSerializer.Serialize(sveStavke);
            
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", tekst);
            syncStatus = $"✅ {sveStavke.Count} stavke su uspješno kopirane! Sada otvorite WEB stranicu i zalijepite ih.";
        }
        catch (Exception ex)
        {
            syncStatus = $"❌ Greška prilikom kopiranja: {ex.Message}";
        }
    }

    // PRODUKCIJSKI KORAK: Prima tekst s računala i urezuje stavke na server
    private async Task UveziPodatkeIzTeksta()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(jsonTekst))
            {
                syncStatus = "❌ Polje za tekst je prazno. Molimo zalijepite kôd.";
                return;
            }

            var stavkeZaUvoz = JsonSerializer.Deserialize<List<TodoItem>>(jsonTekst);
            if (stavkeZaUvoz == null || stavkeZaUvoz.Count == 0)
            {
                syncStatus = "❌ Tekst nije ispravan ili ne sadrži stavke.";
                return;
            }

            using (var prodContext = DbFactory.CreateDbContext())
            {
                await prodContext.Database.ExecuteSqlRawAsync("DELETE FROM Todos;");

                foreach (var stavka in stavkeZaUvoz)
                {
                    var novaStavka = new TodoItem
                    {
                        Title = stavka.Title,
                        Sifra = stavka.Sifra,
                        IsDone = stavka.IsDone,
                        DueDate = stavka.DueDate,
                        PdfContent = stavka.PdfContent,
                        PdfFileName = stavka.PdfFileName
                    };
                    prodContext.Todos.Add(novaStavka);
                }
                await prodContext.SaveChangesAsync(); todos = await prodContext.Todos.ToListAsync();
            }
            jsonTekst = ""; syncStatus = $"🚀 Uspjeh! Na webu se sada nalaze sve {todos.Count} stavke."; StateHasChanged();
        }
        catch (Exception ex) { syncStatus = $"❌ Greška tijekom uvoza: {ex.Message}"; }
    }
}

