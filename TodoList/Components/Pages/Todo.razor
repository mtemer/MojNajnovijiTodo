@page "/"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<TodoDbContext> DbFactory

<h3>Todo (@todos.Count(todo => !todo.IsDone))</h3>

<ul>
    @foreach (var todo in todos)
    {
        <li style="margin-bottom: 8px; list-style-type: none; display: flex; align-items: center;">
            <!-- Dodan checkbox koji aktivira ToggleDone promjenu u bazi -->
            <input type="checkbox" checked="@todo.IsDone" @onchange="(e) => ToggleDone(todo, e)" style="margin-right: 10px;" />

            <span style="@(todo.IsDone ? "text-decoration: line-through; color: gray;" : "")">
                @todo.Title
            </span>

            <!-- Prikaz datuma ako je postavljen -->
            @if (todo.DueDate.HasValue)
            {
                <span style="margin-left: 10px; font-size: 0.85em; color: #666; background-color: #f0f0f0; padding: 2px 6px; border-radius: 4px;">
                    📅 @todo.DueDate.Value.ToString("dd.MM.yyyy.")
                </span>
            }

            <!-- GUMB ZA BRISANJE -->
            <button @onclick="() => DeleteTodo(todo)" style="margin-left: 15px; color: red;">
                Briši
            </button>
        </li>
    }
</ul>

<!-- Input polja za novi zadatak i datum -->
<input placeholder="Something todo" @bind="newTodo" />
<input type="date" @bind="newTodoDueDate" style="margin-left: 5px;" />
<button @onclick="AddTodo" style="margin-left: 5px;">Add todo</button>

@code {
    private List<TodoItem> todos = [];
    private string? newTodo;

    // Nova varijabla za povezivanje s input poljem za datum
    private DateTime? newTodoDueDate;

    // Učitavanje podataka iz SQLite baze čim se stranica otvori
    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        todos = await context.Todos.ToListAsync();
    }

    // Dodavanje novog zadatka u bazu
    private async Task AddTodo()
    {
        if (!string.IsNullOrWhiteSpace(newTodo))
        {
            // Dodano polje DueDate prilikom kreiranja objekta
            var newItem = new TodoItem { Title = newTodo, IsDone = false, DueDate = newTodoDueDate };

            using var context = DbFactory.CreateDbContext();
            context.Todos.Add(newItem);
            await context.SaveChangesAsync();

            todos.Add(newItem); // Ažuriranje sučelja
            newTodo = string.Empty;
            newTodoDueDate = null; // Resetiranje polja za datum nakon unosa
        }
    }

    // Promjena statusa (Dovršeno / Aktivno) u bazi
    private async Task ToggleDone(TodoItem todo, ChangeEventArgs e)
    {
        todo.IsDone = (bool)(e.Value ?? false);

        using var context = DbFactory.CreateDbContext();
        context.Todos.Update(todo);
        await context.SaveChangesAsync();
    }

    // Brisanje iz baze
    private async Task DeleteTodo(TodoItem todoToRemove)
    {
        using var context = DbFactory.CreateDbContext();
        context.Todos.Remove(todoToRemove);
        await context.SaveChangesAsync();

        todos.Remove(todoToRemove); // Ažuriranje sučelja
    }
}

