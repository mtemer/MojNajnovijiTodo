<!DOCTYPE html>
<html lang="hr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="TodoList.styles.css" />
    <HeadOutlet />
</head>

<body>
    <Routes />

    <!-- Ako ste dodavali skriptu za osvježavanje iz prošlog koraka, ona ide ovdje -->
    <script src="/_framework/aspnetcore-browser-refresh.js"></script>
    <script src="_framework/blazor.web.js"></script>

    <script>
        window.otvoriPdfIzBajtova = async (imeDatoteke, streamRef) => {
        // 1. Primamo sirovi stream bajtova iz .NET-a
        const arrayBuffer = await streamRef.arrayBuffer();

        // 2. Pretvaramo ga u siguran Blob objekt unutar memorije preglednika
        const blob = new Blob([arrayBuffer], { type: 'application/pdf' });

        // 3. Kreiramo privremenu adresu koju preglednik obožava i ne blokira
        const blobUrl = URL.createObjectURL(blob);

        // 4. Otvaramo PDF u novom prozoru
        window.open(blobUrl, '_blank');
        };
    </script>

    <!-- TOČNO OVDJE ZALIJEPITE SCRIPT ZA PDF -->
    <script>
        let pdfWindow = null;

        window.preparePdfWindow = () => {
        pdfWindow = window.open("about:blank", "_blank");
        };

        window.viewPdfFromStream = async (contentStreamReference) => {
        if (!pdfWindow) return;

        try {
        const arrayBuffer = await contentStreamReference.arrayBuffer();
        const blob = new Blob([arrayBuffer], { type: 'application/pdf' });
        const url = URL.createObjectURL(blob);

        pdfWindow.location.href = url;
        } catch (error) {
        console.error("Greška prilikom učitavanja PDF-a:", error);
        pdfWindow.close();
        }
        };
    </script>
</body>

</html>